{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile.control"
  },
  "deploy": {
    "startCommand": "python scripts/railway_entry.py",
    "restartPolicyType": "ON_FAILURE",
    "cronSchedule": null,
    "healthcheckPath": "/health"
  }
}
