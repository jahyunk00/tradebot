{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pip install -r requirements-deploy.txt"
  },
  "deploy": {
    "startCommand": "python scripts/railway_trade.py",
    "cronSchedule": "35 13 * * 1-5",
    "restartPolicyType": "NEVER"
  }
}
