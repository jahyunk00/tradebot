# Copy to .env and fill in values.

# Required for LLM analysis
ANTHROPIC_API_KEY=sk-ant-...

# Robinhood MCP OAuth (tokens saved to .tokens/ after first desktop login)
ROBINHOOD_MCP_URL=https://agent.robinhood.com/mcp/trading
ROBINHOOD_OAUTH_SERVER_URL=https://agent.robinhood.com

# Local OAuth callback (must match redirect URI registered during MCP auth)
OAUTH_REDIRECT_URI=http://localhost:8765/callback
